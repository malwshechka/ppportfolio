@page
@model WebApplication4.Areas.Identity.Pages.Account.ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Пароль сброшен";
}

<div class="container py-5" style="max-width: 500px;">
    <div class="card shadow">
        <div class="card-body">
            <h2 class="text-center mb-4">Пароль сброшен</h2>
            <p class="text-center mb-4">
                Ваш пароль был успешно сброшен. <a asp-page="./Login">Войдите в систему</a>.
            </p>
        </div>
    </div>
</div>