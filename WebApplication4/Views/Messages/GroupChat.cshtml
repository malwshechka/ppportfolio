@model List<WebApplication4.Models.GroupMessage>
@using WebApplication4.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@inject AppDbContext DbContext
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = ViewBag.GroupName ?? "Групповой чат";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var conversationId = ViewBag.ConversationId as int? ?? 0;
    var members = ViewBag.Members as List<WebApplication4.Models.GroupMember>;
    var memberCount = members?.Count(m => !m.Left) ?? 0;
}
<div class="messages-layout">
    <div class="chat-list-sidebar">
        <div style="padding: 12px 16px; border-bottom: 1px solid var(--border);">
            <form method="get" asp-action="Index" style="position: relative;">
                <i class="bi bi-search" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #999; font-size: 18px;"></i>
                <input type="text" name="search" class="form-control" placeholder="Поиск чатов"
                       style="padding-left: 48px; border-radius: 20px; background: #f5f5f5; border: 1px solid var(--border);" />
            </form>
        </div>
        <div class="chat-list">
            @if (ViewBag.Threads != null)
            {
                foreach (var thread in ViewBag.Threads as List<WebApplication4.Controllers.MessageThreadViewModel>)
                {
                    <a asp-action="Chat" asp-route-id="@thread.Id" asp-route-isGroup="@(thread.Type == "group")"
                       class="chat-item d-flex align-items-center p-3 text-decoration-none @(thread.Id == conversationId ? "active" : "")">
                        <div style="position: relative; margin-right: 12px; flex-shrink: 0;">
                            @if (thread.Type == "group")
                            {
                                <!-- 🔹 ГРУППА: белый фон + лимонная обводка + первая буква -->
                                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                     style="width: 48px; height: 48px; border: 2px solid var(--accent); color: #111; font-size: 18px;">
                                    @(thread.GroupName?.Substring(0, 1).ToUpper() ?? "G")
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(thread.OtherUser?.ProfilePhotoUrl))
                            {
                                <!-- 🔹 ПОЛЬЗОВАТЕЛЬ С ФОТО: лимонная обводка -->
                                <img src="@thread.OtherUser.ProfilePhotoUrl" class="rounded-circle"
                                     style="width: 48px; height: 48px; object-fit: cover; border: 2px solid var(--accent);">
                            }
                            else
                            {
                                <!-- 🔹 ПОЛЬЗОВАТЕЛЬ БЕЗ ФОТО: белый фон + лимонная обводка + первая буква -->
                                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                     style="width: 48px; height: 48px; border: 2px solid var(--accent); color: #111; font-size: 18px;">
                                    @(thread.OtherUser?.DisplayName?.Substring(0, 1).ToUpper() ?? "?")
                                </div>
                            }
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <h6 class="mb-0 fw-bold" style="font-size: 14px; color: #212121; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @(thread.Type == "group" ? thread.GroupName : thread.OtherUser?.DisplayName)
                            </h6>
                            <small class="text-muted text-truncate" style="font-size: 12px;">
                                @(thread.LastMessageText?.Length > 30 ? thread.LastMessageText.Substring(0, 30) + "..." : thread.LastMessageText ?? "Нет сообщений")
                            </small>
                        </div>
                    </a>
                }
            }
        </div>
    </div>
    <div class="chat-main">
        <div class="chat-header d-flex align-items-center justify-content-between px-4 py-3">
            <div class="d-flex align-items-center gap-3">
                <!-- 🔹 АВАТАР ГРУППЫ: белый фон + лимонная обводка + первая буква -->
                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center fw-bold"
                     style="width:44px;height:44px; border: 2px solid var(--accent); color: #111;">
                    @((ViewBag.GroupName as string)?.Substring(0, 1).ToUpper() ?? "G")
                </div>
                <div>
                    <h6 class="mb-0 fw-bold" style="color: #212121;">@ViewBag.GroupName</h6>
                    <small class="text-muted" style="font-size: 12px;">@memberCount участников</small>
                </div>
            </div>
            <div class="dropdown" style="position: relative; z-index: 1080;">
                <button class="btn btn-light rounded-circle p-2 border-0" type="button"
                        data-bs-toggle="dropdown" aria-expanded="false"
                        style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-three-dots-vertical" style="color: #666; font-size: 18px;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0"
                    style="min-width: 220px; z-index: 1090 !important; border-radius: 12px; padding: 4px 0;">
                    <li>
                        <form asp-action="ClearChat" method="post" class="d-inline w-100">
                            <input type="hidden" name="id" value="@conversationId" />
                            <input type="hidden" name="isGroup" value="true" />
                            <button type="submit" class="dropdown-item py-2 px-3" onclick="return confirm('Очистить чат?')">
                                <i class="bi bi-trash me-2"></i>Очистить чат
                            </button>
                        </form>
                    </li>
                    <li>
                        <button type="button" class="dropdown-item text-danger py-2 px-3" data-bs-toggle="modal" data-bs-target="#leaveGroupModal">
                            <i class="bi bi-box-arrow-right me-2"></i>Покинуть группу
                        </button>
                    </li>
                </ul>
            </div>
        </div>
        <div class="chat-messages flex-grow-1 overflow-auto px-4 py-3" id="chatContainer" style="background: #f8f9fa;">
            @if (Model != null && Model.Any())
            {
                foreach (var msg in Model)
                {
                    var isMe = msg.SenderId == currentUserId;
                    <div class="message-wrapper d-flex @(isMe ? "justify-content-end" : "justify-content-start") mb-3">
                        <div class="message-bubble @(isMe ? "message-me" : "message-them") px-4 py-3 position-relative group-hover">
                            @if (!isMe)
                            {
                                <small class="text-muted d-block mb-1" style="font-size: 11px;">@msg.Sender?.DisplayName</small>
                            }
                            <p class="mb-2 message-text" style="line-height: 1.4; white-space: pre-wrap; margin: 0;" id="text-@msg.Id">@msg.Text</p>
                            <div class="d-flex @(isMe ? "justify-content-end" : "justify-content-start") align-items-center gap-2" style="font-size: 11px; opacity: 0.7;">
                                <span>@msg.CreatedAt.ToString("HH:mm")</span>
                                @if (msg.IsEdited)
                                {
                                    <span>(изм.)</span>
                                }
                                @if (isMe)
                                {
                                    <div class="message-actions" style="display: none; position: absolute; right: -40px; top: 50%; transform: translateY(-50%);">
                                        <button type="button" class="btn btn-sm btn-light border-0 action-btn" onclick="startEdit(@msg.Id)" title="Редактировать">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-light border-0 action-btn text-danger" onclick="deleteMsg(@msg.Id)" title="Удалить">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                            @if (isMe)
                            {
                                <div id="edit-box-@msg.Id" class="edit-box" style="display: none; margin-top: 8px;">
                                    <!-- Должно быть memberUsernames, а НЕ memberEmails! -->
            <textarea name="memberUsernames" class="form-control" rows="4" placeholder="username1, username2..."></textarea>
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="cancelEdit(@msg.Id)">Отмена</button>
                                        <button type="button" class="btn btn-sm btn-primary" onclick="saveEdit(@msg.Id, true)">Сохранить</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-chat-square-text d-block mb-3" style="font-size: 48px; opacity: 0.4;"></i>
                    <p class="mb-0">Пока нет сообщений</p>
                </div>
            }
        </div>
        <div class="chat-input px-4 py-3" style="border-top: 1px solid var(--border); background: #fff;">
            <form asp-controller="Messages" asp-action="Send" method="post" class="d-flex gap-2">
                <input type="hidden" name="conversationId" value="@conversationId" />
                <input type="hidden" name="isGroup" value="true" />
                <input type="text" name="text" class="form-control" placeholder="Написать сообщение..." required autocomplete="off"
                       style="flex: 1; border-radius: 24px; border: 1px solid var(--border); padding: 12px 20px; background: #f9f9f9;" />
                <button type="submit" class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center"
                        style="width: 48px; height: 48px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none;">
                    <i class="bi bi-send-fill"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Модальное окно: Покинуть группу -->
<div class="modal fade" id="leaveGroupModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Покинуть группу?</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="DeleteChat" method="post">
                    <input type="hidden" name="id" value="@conversationId" />
                    <input type="hidden" name="isGroup" value="true" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-sm">Покинуть</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Отмена</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .message-wrapper:hover .message-actions {
        display: flex !important;
    }

    .action-btn {
        width: 28px;
        height: 28px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .edit-box textarea {
        font-size: 14px;
        border-radius: 8px;
    }

    .message-bubble {
        max-width: 60% !important;
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .message-me {
        background: linear-gradient(135deg, #F0F8C5 0%, #E1FF8C 100%);
        color: #111;
        border-bottom-right-radius: 4px !important;
    }

    .message-them {
        background: #fff;
        color: #212121;
        border: 1px solid var(--border);
        border-bottom-left-radius: 4px !important;
    }

    .chat-list::-webkit-scrollbar {
        width: 6px;
    }

    .chat-list::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 3px;
    }

    .chat-messages::-webkit-scrollbar {
        width: 6px;
    }

    .chat-messages::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 3px;
    }

    .alert-thin {
        font-weight: 400;
        padding: 8px 16px;
        border-radius: 8px;
        border: none;
    }

    .chat-item {
        transition: background 0.2s;
        border-bottom: 1px solid var(--border-light) !important;
    }

        .chat-item:hover {
            background: var(--bg-secondary) !important;
        }

        .chat-item.active {
            background: var(--hero-bg) !important;
        }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var container = document.getElementById('chatContainer');
        if (container) container.scrollTop = container.scrollHeight;
    });
    function startEdit(id) {
        document.getElementById('text-' + id).style.display = 'none';
        document.getElementById('edit-box-' + id).style.display = 'block';
    }
    function cancelEdit(id) {
        document.getElementById('text-' + id).style.display = 'block';
        document.getElementById('edit-box-' + id).style.display = 'none';
    }
    async function saveEdit(id, isGroup) {
        const newText = document.getElementById('edit-input-' + id).value;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        if (!newText) return;
        try {
            const response = await fetch('/Messages/EditMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
                body: `messageId=${id}&text=${encodeURIComponent(newText)}&isGroup=${isGroup}`
            });
            if (response.ok) {
                const textEl = document.getElementById('text-' + id);
                textEl.innerText = newText;
                if (!textEl.innerText.includes('(изм.)')) { textEl.innerText += ' (изм.)'; }
                cancelEdit(id);
            }
        } catch (error) { console.error('Ошибка редактирования:', error); }
    }
    async function deleteMsg(id) {
        if(!confirm("Удалить сообщение?")) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        try {
            const response = await fetch('/Messages/DeleteMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
                body: `messageId=${id}&isGroup=true`
            });
            if (response.ok) {
                const wrapper = document.getElementById('text-' + id).closest('.message-wrapper');
                if(wrapper) wrapper.remove();
            }
        } catch (error) { console.error('Ошибка удаления:', error); }
    }
</script>