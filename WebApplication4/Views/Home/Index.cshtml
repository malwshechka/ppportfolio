@using WebApplication4.Models
@using Microsoft.AspNetCore.Identity
@model IEnumerable<Project>
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "DevPortfolio - Платформа для разработчиков";
    var currentUserId = User.Identity?.IsAuthenticated == true ? UserManager.GetUserId(User) : null;
}

@Html.AntiForgeryToken()

<section class="hero-pro">
    <div class="hero-noise"></div>
    <div class="hero-glow"></div>

    <div class="container hero-pro-inner">
        <div class="cursor-glow"></div>
        <div class="hero-content">

            <div class="hero-chip">
                🚀 Сообщество разработчиков
            </div>

            <h1 class="hero-title-pro">
                Делись проектами.<br>
                Получай <span>честный фидбек</span>.<br>
                Расти быстрее.
            </h1>

            <p class="hero-desc">
                Платформа, где твои проекты не просто лежат —
                их оценивают, обсуждают и помогают тебе расти.
            </p>

            <div class="hero-actions-pro">
                @if (!User.Identity?.IsAuthenticated ?? true)
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn-main">
                        Войти
                    </a>
                }
                else if (!User.IsInRole("Admin"))
                {
                    <a asp-controller="Profile" asp-action="CreateProject" class="btn-main">
                        Создать проект
                    </a>
                }

                <a href="#projects-grid" class="btn-ghost">
                    Смотреть проекты
                </a>
            </div>

        </div>

        <div class="hero-visual">
            <div class="floating-card">
                <div class="card-top">
                    <div class="dots">
                        <span></span><span></span><span></span>
                    </div>
                    <span>project.jsx</span>
                </div>
                <div class="card-body">
                    <div class="line w80"></div>
                    <div class="line w60"></div>
                    <div class="line w90 accent"></div>
                    <div class="line w50"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-4 border-bottom bg-white">
    <div class="container-fluid px-4">
        <form asp-controller="Home" asp-action="Index" method="get">
            <div class="row g-3 align-items-center mb-3">
                <div class="col-lg-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Поиск проектов, технологий..." value="@ViewBag.CurrentSearch" />
                    </div>
                </div>

                <div class="col-lg-3">
                    <select name="appTypeId" class="form-select">
                        <option value="">Все типы</option>
                        @if (ViewBag.AppTypes != null)
                        {
                            foreach (var type in ViewBag.AppTypes)
                            {
                                <option value="@type.Id" selected="@(ViewBag.AppTypeId == type.Id)">@type.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-lg-2">
                    <select name="complexityId" class="form-select">
                        <option value="">Любая сложность</option>
                        @if (ViewBag.ComplexityLevels != null)
                        {
                            foreach (var level in ViewBag.ComplexityLevels)
                            {
                                <option value="@level.Id" selected="@(ViewBag.ComplexityId == level.Id)">@level.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-lg-2">
                    <button type="submit" class="btn btn-primary w-100" style="height: 42px;">Найти</button>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12 d-flex justify-content-end align-items-center gap-3">
                    <span class="text-muted small">Сортировка:</span>
                    <div class="btn-group btn-group-sm">
                        <a asp-action="Index" asp-route-sortBy="date" class="btn btn-outline-secondary @(ViewBag.CurrentSort == "date" ? "active" : "")">Дата</a>
                        <a asp-action="Index" asp-route-sortBy="rating" class="btn btn-outline-secondary @(ViewBag.CurrentSort == "rating" ? "active" : "")">Рейтинг</a>
                        <a asp-action="Index" asp-route-sortBy="popularity" class="btn btn-outline-secondary @(ViewBag.CurrentSort == "popularity" ? "active" : "")">Популярность</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

<section class="py-5 bg-light" id="projects-grid">
    <div class="container-fluid px-4">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-muted bg-white rounded shadow-sm">
                <i class="bi bi-folder-x d-block mb-3" style="font-size: 48px; opacity: 0.5;"></i>
                <h4 class="mb-2">Проекты не найдены</h4>
                <p>Попробуйте изменить параметры поиска</p>
                @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch) || ViewBag.AppTypeId != null || ViewBag.ComplexityId != null)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Сбросить фильтры</a>
                }
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var project in Model)
                {
                    var isFav = currentUserId != null && project.Favorites?.Any(f => f.UserId == currentUserId) == true;
                    <div class="col-md-6 col-lg-4">
                        <div class="project-card h-100 d-flex flex-column bg-white">
                            <div class="card-body flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(project.ApplicationUser?.ProfilePhotoUrl))
                                        {
                                            <img src="@project.ApplicationUser.ProfilePhotoUrl" alt="Фото профиля" class="rounded-circle" style="width: 36px; height: 36px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                                                @(project.ApplicationUser?.DisplayName?.Length > 0 ? project.ApplicationUser.DisplayName.Substring(0, 1).ToUpper() : "?")
                                            </div>
                                        }
                                        <a asp-controller="Projects" asp-action="UserPortfolio" asp-route-userId="@project.ApplicationUserId" class="text-decoration-none small">@project.ApplicationUser?.DisplayName</a>
                                    </div>

                                    @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
                                    {
                                        <button type="button" class="btn btn-sm p-0 favorite-toggle border-0 bg-transparent"
                                                data-project-id="@project.Id" title="@(isFav ? "Убрать из избранного" : "В избранное")">
                                            <i class="bi @(isFav ? "bi-heart-fill text-danger" : "bi-heart text-secondary")"
                                               style="font-size: 1.25rem; transition: color 0.2s;"></i>
                                        </button>
                                    }
                                </div>

                                <h5 class="card-title mb-2">@project.Title</h5>
                                <p class="card-text text-secondary small mb-3">@(project.Description?.Length > 110 ? project.Description.Substring(0, 110) + "..." : project.Description ?? "Нет описания")</p>

                                <div class="tech-tags mb-3">
                                    @if (project.ProjectTechnologies != null)
                                    {
                                        foreach (var pt in project.ProjectTechnologies.Take(4))
                                        {
                                            <span class="tech-tag">@pt.Technology?.Name</span>
                                        }
                                    }
                                </div>

                                <div class="d-flex justify-content-between align-items-center pt-3 border-top border-subtle">
                                    <span class="badge bg-secondary">@project.Status?.Name</span>
                                    <div class="d-flex align-items-center gap-1">
                                        @if (project.Reviews?.Any() == true)
                                        {
                                            var avg = project.Reviews.Average(r => r.Rating);
                                            <i class="bi bi-star-fill text-warning"></i>
                                            <span class="fw-medium">@avg.ToString("F1")</span>
                                            <span class="text-muted small">(@project.Reviews.Count)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Нет оценок</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="card-footer bg-white border-0 pb-3">
                                <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id" class="btn btn-primary w-100 btn-sm">Подробнее</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <section class="py-5 bg-white border-top border-bottom">
        <div class="container-fluid px-4 text-center">
            <h4 class="fw-bold mb-3">Готовы показать свои работы?</h4>
            <p class="text-muted mb-4">Присоединяйтесь к сообществу разработчиков</p>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg px-5" style="border: 3px solid #f8f9fa;">Войти</a>
        </div>
    </section>
}

@section Scripts {
    <script>
        // Плавная прокрутка
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) { target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
            });
        });

        // Избранное
        document.querySelectorAll('.favorite-toggle').forEach(btn => {
            btn.addEventListener('click', async function() {
                const projectId = this.dataset.projectId;
                const icon = this.querySelector('i');
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                if (!token) {
                    console.error('CSRF token not found');
                    return;
                }

                try {
                    const response = await fetch('/Favorites/Toggle', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: `projectId=${projectId}`
                    });

                    if (response.ok) {
                        if (icon.classList.contains('bi-heart')) {
                            icon.classList.replace('bi-heart', 'bi-heart-fill');
                            icon.classList.replace('text-secondary', 'text-danger');
                            this.setAttribute('title', 'Убрать из избранного');
                        } else {
                            icon.classList.replace('bi-heart-fill', 'bi-heart');
                            icon.classList.replace('text-danger', 'text-secondary');
                            this.setAttribute('title', 'В избранное');
                        }
                    }
                } catch (error) {
                    console.error('Ошибка:', error);
                }
            });
        });
    </script>
}