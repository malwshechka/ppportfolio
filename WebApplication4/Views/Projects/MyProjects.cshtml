@model List<WebApplication4.Models.Project>

@{
    ViewData["Title"] = "Мои проекты";
}

<h1>Мои проекты</h1>

<a asp-action="Create" class="btn btn-success mb-3">+ Добавить новый проект</a>

@if (Model == null || Model.Count == 0)
{
    <p class="text-muted">У вас пока нет добавленных проектов.</p>
}
else
{
    <div class="row">
        @foreach (var project in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@project.Title</h5>
                        <p class="card-text">@project.Description</p>

                        <p>
                            <strong>Статус:</strong> @project.Status?.Name <br />
                            <strong>Тип:</strong> @project.AppType?.Name <br />
                            <strong>Сложность:</strong> @project.ComplexityLevel?.Name
                        </p>

                        <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-primary btn-sm">Подробнее</a>
                    </div>
                </div>
            </div>
        }
    </div>
}