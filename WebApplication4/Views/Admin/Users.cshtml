@model List<WebApplication4.Models.ApplicationUser>
@{
    ViewData["Title"] = "Управление пользователями";
}
<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Пользователи</h1>
            <p class="text-muted mb-0">Управление аккаунтами и доступом</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Назад
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-lemon shadow-sm alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Users" method="get" class="d-flex gap-2">
                <div class="flex-grow-1">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" name="search" class="form-control border-start-0 ps-0"
                               placeholder="Поиск по Email, имени или отображаемому имени..."
                               value="@ViewBag.CurrentSearch" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Найти</button>
                @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
                {
                    <a asp-action="Users" class="btn btn-outline-secondary">Сбросить</a>
                }
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4" style="min-width: 280px;">Пользователь</th>
                            <th style="min-width: 220px;">Email</th>
                            <th style="min-width: 130px;">Регистрация</th>
                            <th style="min-width: 120px;">Статус</th>
                            <th style="min-width: 90px;">Проекты</th>
                            <th class="text-end pe-4" style="min-width: 180px;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            var isBlocked = user.IsBanned;
                            var isAdmin = user.Email?.ToLower() == "admin@portfolio.com";
                            var initial = !string.IsNullOrEmpty(user.DisplayName)
                            ? user.DisplayName.Substring(0, 1).ToUpper()
                            : (!string.IsNullOrEmpty(user.Email) ? user.Email.Substring(0, 1).ToUpper() : "U");
                            var projectsCount = ViewBag.ProjectsCount != null && ViewBag.ProjectsCount.ContainsKey(user.Id)
                            ? ViewBag.ProjectsCount[user.Id] : 0;

                            <tr class="@(isBlocked ? "table-danger" : "")">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(user.ProfilePhotoUrl))
                                        {
                                            <img src="@user.ProfilePhotoUrl" alt="Фото"
                                                 class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover; flex-shrink: 0;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary text-secondary rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                                 style="width: 40px; height: 40px; flex-shrink: 0;">
                                                @initial
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-medium">
                                                <a asp-controller="Projects" asp-action="UserPortfolio" asp-route-userId="@user.Id" asp-route-fromAdmin="true" class="text-decoration-none">
                                                    @(user.DisplayName ?? user.UserName)
                                                </a>
                                                @if (isAdmin)
                                                {
                                                    <span class="badge bg-primary ms-2" style="background-color: #4200FF; color: #fff;">Админ</span>
                                                }
                                            </div>
                                            <small class="text-muted">@user.Skills</small>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="text-muted">@user.Email</span></td>
                                <td>
                                    <small class="text-muted">
                                        @user.RegisteredAt?.ToString("dd.MM.yyyy")<br>
                                        <span class="text-secondary">@user.RegisteredAt?.ToString("HH:mm")</span>
                                    </small>
                                </td>
                                <td>
                                    @if (isBlocked)
                                    {
                                        <span class="badge border-0 text-dark" style="background: #FEF2F2; color: #B42318;">
                                            <i class="bi bi-lock me-1"></i>Заблокирован
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge border-0 text-dark" style="background: #ECFDF5; color: #047857;">
                                            <i class="bi bi-check-circle me-1"></i>Активен
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (isAdmin)
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                    else
                                    {
                                        <span class="fw-medium">@projectsCount</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if (!isAdmin)
                                    {
                                        <form asp-action="ToggleBan" method="post" asp-route-userId="@user.Id" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            @if (user.IsBanned)
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                    <i class="bi bi-unlock me-1"></i>Разблокировать
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Заблокировать пользователя? Ему будут доступны только публичные просмотры.')">
                                                    <i class="bi bi-ban me-1"></i>Заблокировать
                                                </button>
                                            }
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    var isActive = i == ViewBag.CurrentPage;
                    <li class="page-item @(isActive ? "active" : "")">
                        <a class="page-link" asp-action="Users" asp-route-search="@ViewBag.CurrentSearch" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>