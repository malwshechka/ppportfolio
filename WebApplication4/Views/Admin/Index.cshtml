@model WebApplication4.Controllers.AdminDashboardViewModel
@{
    ViewData["Title"] = "Панель администратора";
}

<div class="container-fluid py-4 px-4">
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">
                Панель администратора
            </h1>
            <p class="text-muted mb-0">Управление системой DevPortfolio</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-box-arrow-up-right me-1"></i>На сайт
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-lemon shadow-sm alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- STATS -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card h-100">
                <div class="d-flex align-items-center justify-content-center mb-3" style="background: #E1FF8C; width: 60px; height: 60px; border-radius: 50%; margin: 0 auto;">
                    <i class="bi bi-people fs-3" style="color: #111111;"></i>
                </div>
                <h3 class="mb-1">@Model.TotalUsers</h3>
                <p class="text-secondary mb-0">Пользователей</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card h-100">
                <div class="d-flex align-items-center justify-content-center mb-3" style="background: rgba(225, 255, 140, 0.3); width: 60px; height: 60px; border-radius: 50%; margin: 0 auto;">
                    <i class="bi bi-folder2-open fs-3" style="color: #555;"></i>
                </div>
                <h3 class="mb-1">@Model.TotalProjects</h3>
                <p class="text-secondary mb-0">Проектов</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card h-100">
                <div class="d-flex align-items-center justify-content-center mb-3" style="background: #FFFAEB; width: 60px; height: 60px; border-radius: 50%; margin: 0 auto;">
                    <i class="bi bi-hourglass-split fs-3" style="color: #B54708;"></i>
                </div>
                <h3 class="mb-1">@Model.PendingProjects</h3>
                <p class="text-secondary mb-0">На модерации</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card h-100">
                <div class="d-flex align-items-center justify-content-center mb-3" style="background: #ECFDF5; width: 60px; height: 60px; border-radius: 50%; margin: 0 auto;">
                    <i class="bi bi-chat-square-text fs-3" style="color: #027A48;"></i>
                </div>
                <h3 class="mb-1">@Model.TotalReviews</h3>
                <p class="text-secondary mb-0">Отзывов</p>
            </div>
        </div>
    </div>

    <!-- MAIN GRID -->
    <div class="row g-4">
        <!-- PROJECTS -->
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header bg-transparent border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0 fw-bold">
                        <i class="bi bi-clock-history me-2 text-muted"></i>
                        Последние проекты
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.RecentProjects.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-folder-x fs-1 mb-2 d-block"></i>
                            <p class="mb-0">Пока нет проектов</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4 border-0">Проект</th>
                                        <th class="border-0">Автор</th>
                                        <th class="border-0">Дата</th>
                                        <th class="text-end pe-4 border-0">Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var project in Model.RecentProjects)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id" asp-route-fromAdmin="true" class="text-decoration-none fw-bold">
                                                    @project.Title
                                                </a>
                                                <div class="small text-muted text-truncate" style="max-width: 200px;">
                                                    @(project.Description?.Length > 40 ? project.Description.Substring(0, 40) + "..." : project.Description)
                                                </div>
                                            </td>
                                            <td>
                                                <a asp-controller="Projects" asp-action="UserPortfolio" asp-route-userId="@project.ApplicationUserId" asp-route-fromAdmin="true" class="text-decoration-none small">
                                                    @project.ApplicationUser?.DisplayName
                                                </a>
                                            </td>
                                            <td><small class="text-muted">@project.CreatedAt.ToString("dd.MM")</small></td>
                                            <td class="text-end pe-4">
                                                @if (project.ModerationStatus == WebApplication4.Models.ModerationStatus.Pending)
                                                {
                                                    <span class="badge" style="background: #FFFAEB; color: #B54708; border: 1px solid #FEDF89;">На модерации</span>
                                                }
                                                else if (project.ModerationStatus == WebApplication4.Models.ModerationStatus.Approved)
                                                {
                                                    <span class="badge" style="background: #E1FF8C; color: #111111; border: 1px solid #E1FF8C;">Опубликовано</span>
                                                }
                                                else
                                                {
                                                    <span class="badge" style="background: #FEF2F2; color: #B42318; border: 1px solid #FECACA;">Отклонено</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- NAVIGATION - КАК В ПРОФИЛЕ -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-transparent border-bottom py-3">
                    <h5 class="card-title mb-0 fw-bold">
                        <i class="bi bi-list-ul me-2 text-muted"></i>
                        Управление
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        <a asp-action="PendingProjects" class="list-group-item list-group-item-action py-3">
                            <i class="bi bi-shield-check me-2 text-muted"></i>Модерация проектов
                            <small class="d-block text-muted mt-1">@Model.PendingProjects ожидают</small>
                        </a>
                        <a asp-action="Reviews" class="list-group-item list-group-item-action py-3">
                            <i class="bi bi-chat-square-text me-2 text-muted"></i>Отзывы
                            <small class="d-block text-muted mt-1">Всего @Model.TotalReviews</small>
                        </a>
                        <a asp-action="Complaints" class="list-group-item list-group-item-action py-3">
                            <i class="bi bi-exclamation-triangle me-2 text-muted"></i>Жалобы
                            <small class="d-block text-muted mt-1">Управление жалобами</small>
                        </a>
                        <a asp-action="Users" class="list-group-item list-group-item-action py-3">
                            <i class="bi bi-people me-2 text-muted"></i>Пользователи
                            <small class="d-block text-muted mt-1">Всего @Model.TotalUsers</small>
                        </a>
                        <a asp-controller="Favorites" asp-action="Index" class="list-group-item list-group-item-action py-3">
                            <i class="bi bi-heart me-2 text-muted"></i>Избранное
                            <small class="d-block text-muted mt-1">Просмотр проектов</small>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>