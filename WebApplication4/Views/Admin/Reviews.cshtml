@model List<WebApplication4.Models.Review>
@{
    ViewData["Title"] = "Управление отзывами";
}
<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">
                Отзывы
            </h1>
            <p class="text-muted mb-0">Модерация пользовательских отзывов</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Назад
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-chat-square-text fs-1 text-muted mb-3"></i>
                <h5 class="mb-2">Нет отзывов для модерации</h5>
                <p class="text-muted mb-0">Отзывы появятся здесь после их публикации</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Отзыв</th>
                                <th>Автор</th>
                                <th>Проект</th>
                                <th>Оценка</th>
                                <th>Дата</th>
                                <th class="text-end pe-4">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var review in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <p class="mb-1">@review.Text</p>
                                    </td>
                                    <td>
                                        <a asp-controller="Projects" asp-action="UserPortfolio" asp-route-userId="@review.UserId" class="text-decoration-none fw-medium">
                                            @(!string.IsNullOrEmpty(review.User?.DisplayName)
                                                                                ? review.User.DisplayName
                                                                                : (review.User?.UserName ?? "Аноним"))
                                </a>
                            </td>
                            <td>
                                <a asp-controller="Projects" asp-action="Details" asp-route-id="@review.ProjectId"
                                   class="text-decoration-none fw-medium">
                                    @review.Project?.Title
                                </a>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi bi-star-fill @(i <= review.Rating ? "text-warning" : "text-muted opacity-25")"
                                                   style="font-size: 0.85rem;"></i>
                                            }
                                            <span class="ms-1 fw-medium">@review.Rating</span>
                                        </div>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @review.Date.ToString("dd.MM.yyyy")<br>
                                            <span class="text-secondary">@review.Date.ToString("HH:mm")</span>
                                        </small>
                                    </td>
                                    <td class="text-end pe-4">
                                        <form asp-action="DeleteReview" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@review.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Удалить этот отзыв?')">
                                                <i class="bi bi-trash me-1"></i>Удалить
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>