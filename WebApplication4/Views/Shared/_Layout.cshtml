@using Microsoft.AspNetCore.Identity
@using WebApplication4.Models
@using WebApplication4.Areas.Identity.Pages
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    // 🔹 ПЕРЕМЕННЫЕ ДЛЯ ПРОФИЛЯ — ВЫНЕСЕНЫ В НАЧАЛО ФАЙЛА
    var currentUser = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
    var photoUrl = currentUser?.ProfilePhotoUrl;
    var displayName = currentUser?.DisplayName ?? User.Identity?.Name;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DevPortfolio</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Golos+Text:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/site.css" asp-append-version="true" rel="stylesheet" />

    @await RenderSectionAsync("Head", required: false)
</head>
<body class="d-flex flex-column min-vh-100">

    <header class="sticky-top">
        @{
            var bannedNotice = ViewBag.BannedNotice?.ToString();
        }
        @if (!string.IsNullOrEmpty(bannedNotice))
        {
            <div class="alert alert-warning alert-dismissible fade show mb-0 rounded-0 text-center py-2" role="alert" style="background: linear-gradient(90deg, #fff3cd 0%, #ffe69c 100%); border: none; border-bottom: 2px solid #ffc107;">
                <div class="container-fluid px-4 d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-shield-lock-fill fs-5 text-dark"></i>
                    <span class="fw-medium text-dark small">@bannedNotice</span>
                    <button type="button" class="btn-close ms-2" data-bs-dismiss="alert" aria-label="Закрыть"></button>
                </div>
            </div>
        }
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <span style="color: var(--accent);">◆</span> DevPortfolio
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Переключить навигацию">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="projects-grid">Проекты</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">О нас</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (!User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Profile" asp-action="MyProjects">Мои проекты</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Profile" asp-action="Index">Профиль</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Feed" asp-action="Index">Лента</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Profile" asp-action="Subscriptions">Подписки</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Index">Панель админа</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="PendingProjects">Модерация</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Users">Пользователи</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Reviews">Отзывы</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Complaints">Жалобы</a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a asp-controller="Messages" asp-action="Index" class="nav-link position-relative" title="Сообщения">
                                    <i class="bi bi-chat-square"></i>
                                </a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#"
                                   role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @if (!string.IsNullOrEmpty(photoUrl))
                                    {
                                        <img src="@photoUrl" alt="Фото профиля" class="rounded-circle" style="width: 28px; height: 28px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <div class="avatar-sm bg-secondary text-secondary rounded-circle d-flex align-items-center justify-content-center fw-medium" style="width: 28px; height: 28px;">
                                            @(displayName?.Length > 0 ? displayName.Substring(0, 1).ToUpper() : "?")
                                        </div>
                                    }
                                    <span class="d-none d-lg-inline text-secondary">@displayName</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                    @if (!User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                                <i class="bi bi-person me-2"></i>Мой профиль
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="px-3 py-2">
                                            <button type="submit" class="btn btn-outline-danger w-100 text-start btn-sm">
                                                <i class="bi bi-box-arrow-left me-2"></i>Выйти
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary btn-sm">Войти</a>
                            </li>
                            <li class="nav-item">
                                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-sm">Регистрация</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-grow-1" style="margin: 0; padding: 0;">
        @RenderBody()
    </main>

    <footer class="footer mt-auto py-4">
        <div class="container-fluid px-4">
            <div class="row align-items-center">
                <div class="col-md-4 mb-3 mb-md-0">
                    <h5 class="fw-bold mb-2">DevPortfolio</h5>
                    <p class="text-muted small mb-0">Профессиональное сообщество для разработчиков</p>
                </div>

                <div class="col-md-4 text-center mb-3 mb-md-0">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-secondary me-3">Главная</a>
                    <a asp-controller="Home" asp-action="About" class="text-decoration-none text-secondary me-3">О нас</a>
                    <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-secondary">Конфиденциальность</a>
                </div>

                <div class="col-md-4 text-md-end">
                    <p class="text-muted small mb-0">© 2026 DevPortfolio. Все права защищены.</p>
                    <a href="mailto:support@devportfolio.com" class="text-decoration-none text-secondary small">support@devportfolio.com</a>
                </div>
            </div>
        </div>
    </footer>
   <script>
const card = document.querySelector(".floating-card");

document.addEventListener("mousemove", (e) => {
    if (!card) return;

    let x = (window.innerWidth / 2 - e.clientX) / 25;
    let y = (window.innerHeight / 2 - e.clientY) / 25;

    card.style.transform = `rotate(-4deg) translate(${x}px, ${y}px)`;
});
</script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>